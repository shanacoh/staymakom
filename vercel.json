{
  "redirects": [
    { "source": "/hotel-old/:slug", "destination": "/hotel/:slug", "permanent": true },
    { "source": "/experience-old/:slug", "destination": "/experience/:slug", "permanent": true },
    { "source": "/experiences-old", "destination": "/experiences", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [{ "source": "/((?!.*\\.).+)", "destination": "/index.html" }]
}
